{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug FastAPI Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/backend",
      "args": [
        "app.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "3001"
      ],
      "env": {
        "FRONTEND_ORIGIN": "http://127.0.0.1:5173"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
